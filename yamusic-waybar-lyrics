import base64
import bisect
import datetime
import hashlib
import hmac
import json
import os
from pathlib import Path
import queue
import re
import subprocess
import sys
import threading
import time
import urllib.parse
import urllib.request

import dbus


ANSI_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
LRC_RE = re.compile(r"\[(\d+):(\d+(?:\.\d+)?)\]\s*(.*)")
LYRIC_ICON = ""
PLAYER = "firefox"
MPRIS_PREFIX = f"org.mpris.MediaPlayer2.{PLAYER}"
STATE_FILE = f"/tmp/yamusic-waybar-lyrics-{os.getuid()}.json"
CACHE_DIR = Path.home() / ".cache" / "yamusic-waybar-lyrics"
MPRIS_CHECK_INTERVAL = 0.2
QUEUE_CHECK_INTERVAL = 0.1
SPTLRX_STALE_AFTER = 30.0
NO_LYRICS_AFTER = 12.0
NO_LYRICS_RETRY_AFTER = 45.0
ANIMATION_INTERVAL = 0.4
LYRIC_LEAD_MS = 300
POSITION_JITTER_MS = 900
SILENCE_FRAMES = ("...", ".. ", ".  ", ".. ")
NO_LYRICS_TEXT = f"{LYRIC_ICON} (no lyrics)"
LRCLIB_TIMEOUT = 1.5
YANDEX_TOKEN = os.environ.get("YANDEX_TOKEN", "")
YANDEX_TIMEOUT = 3.0
NEGATIVE_CACHE_TTL = 3 * 24 * 60 * 60
YANDEX_PUBLIC_SIGN_KEY = "p93jhgh689SBReK6ghtw62"
YANDEX_HEADERS = {
    "Authorization": f"OAuth {YANDEX_TOKEN}",
    "User-Agent": "Yandex-Music-API",
    "X-Yandex-Music-Client": "YandexMusicAndroid/24023621",
}


def metadata_value(value: object) -> str:
    if isinstance(value, (list, tuple, dbus.Array)):
        return ", ".join(str(item) for item in value)
    return str(value or "")


def find_mpris_player(bus: dbus.SessionBus) -> str:
    try:
        return next(
            (str(name) for name in bus.list_names() if str(name).startswith(MPRIS_PREFIX)),
            "",
        )
    except dbus.DBusException:
        return ""


def read_mpris(bus: dbus.SessionBus, player_name: str) -> tuple[str, tuple[str, str, str], int, str]:
    try:
        if not player_name:
            player_name = find_mpris_player(bus)
        if not player_name:
            return "", ("", "", ""), 0, ""

        obj = bus.get_object(player_name, "/org/mpris/MediaPlayer2")
        props = dbus.Interface(obj, "org.freedesktop.DBus.Properties")
        status = str(props.Get("org.mpris.MediaPlayer2.Player", "PlaybackStatus"))
        metadata = props.Get("org.mpris.MediaPlayer2.Player", "Metadata")
        position_ms = int(props.Get("org.mpris.MediaPlayer2.Player", "Position") or 0) // 1000
        return (
            status,
            (
                metadata_value(metadata.get("xesam:title")),
                metadata_value(metadata.get("xesam:artist")),
                metadata_value(metadata.get("xesam:album")),
            ),
            position_ms,
            player_name,
        )
    except dbus.DBusException:
        return "", ("", "", ""), 0, ""


def emit(text: str, css_class: str = "", tooltip: str | None = None) -> None:
    payload = {"text": text, "tooltip": text if tooltip is None else tooltip}
    if css_class:
        payload["class"] = css_class
    print(json.dumps(payload, ensure_ascii=False), flush=True)


def has_track(key: tuple[str, str, str]) -> bool:
    title, artist, _album = key
    return bool(title and artist)


def has_synced_lyrics(key: tuple[str, str, str]) -> bool | None:
    title, artist, _album = key
    params = urllib.parse.urlencode({"track_name": title, "artist_name": artist})
    request = urllib.request.Request(
        f"https://lrclib.net/api/search?{params}",
        headers={"User-Agent": "yamusic-waybar-lyrics/1.0"},
    )
    try:
        with urllib.request.urlopen(request, timeout=LRCLIB_TIMEOUT) as response:
            if response.status >= 300:
                return None
            import json as json_module

            items = json_module.loads(response.read().decode("utf-8"))
            return any(item.get("syncedLyrics") for item in items if isinstance(item, dict))
    except Exception:
        return None


def yandex_result(url: str) -> object | None:
    if not YANDEX_TOKEN:
        return None
    request = urllib.request.Request(url, headers=YANDEX_HEADERS)
    with urllib.request.urlopen(request, timeout=YANDEX_TIMEOUT) as response:
        payload = json.loads(response.read().decode("utf-8"))
    return payload.get("result")


def yandex_sign(track_id: str) -> tuple[int, str]:
    numeric_id = track_id.split(":", 1)[0]
    timestamp = int(datetime.datetime.now().timestamp())
    message = f"{numeric_id}{timestamp}".encode("utf-8")
    value = base64.b64encode(
        hmac.new(YANDEX_PUBLIC_SIGN_KEY.encode("utf-8"), message, hashlib.sha256).digest()
    ).decode("utf-8")
    return timestamp, value


def parse_lrc(text: str) -> list[tuple[int, str]]:
    lines = []
    for raw_line in text.splitlines():
        match = LRC_RE.match(raw_line)
        if not match:
            continue
        line = match.group(3).strip()
        if not line:
            continue
        minutes = int(match.group(1))
        seconds = float(match.group(2))
        lines.append((int((minutes * 60 + seconds) * 1000), line))
    return sorted(lines)


def cache_file(track_id: str) -> Path:
    safe_name = urllib.parse.quote(track_id, safe="")
    return CACHE_DIR / f"{safe_name}.json"


def read_lyrics_cache(track_id: str) -> list[tuple[int, str]] | None:
    path = cache_file(track_id)
    try:
        with open(path, encoding="utf-8") as cached:
            payload = json.load(cached)
        if payload.get("status") == "missing":
            fetched_at = int(payload.get("fetched_at") or 0)
            if time.time() - fetched_at < NEGATIVE_CACHE_TTL:
                return []
            return None
        lines = payload.get("lines") or []
        return [(int(time_ms), str(line)) for time_ms, line in lines if line]
    except Exception:
        return None


def write_lyrics_cache(
    track_id: str,
    key: tuple[str, str, str],
    lines: list[tuple[int, str]] | None,
) -> None:
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        payload = {
            "track_id": track_id,
            "title": key[0],
            "artist": key[1],
            "album": key[2],
            "fetched_at": int(time.time()),
        }
        if lines:
            payload["status"] = "ok"
            payload["lines"] = lines
        else:
            payload["status"] = "missing"
            payload["lines"] = []
        path = cache_file(track_id)
        tmp_path = path.with_suffix(".tmp")
        with open(tmp_path, "w", encoding="utf-8") as cached:
            json.dump(payload, cached, ensure_ascii=False, separators=(",", ":"))
        os.replace(tmp_path, path)
    except Exception:
        pass


def fetch_yandex_lrc(key: tuple[str, str, str]) -> list[tuple[int, str]] | None:
    title, artist, _album = key
    if not YANDEX_TOKEN or not title or not artist:
        return None

    try:
        params = urllib.parse.urlencode({"text": f"{title} {artist}", "type": "track", "page": "0"})
        search = yandex_result(f"https://api.music.yandex.net/search?{params}")
        tracks = (search or {}).get("tracks", {}).get("results", [])

        for track in tracks[:3]:
            track_id = str(track.get("id") or "")
            album_id = str((track.get("albums") or [{}])[0].get("id") or "")
            if not track_id:
                continue
            full_id = f"{track_id}:{album_id}" if album_id else track_id
            cached = read_lyrics_cache(full_id)
            if cached is not None:
                if cached:
                    return cached
                continue

            timestamp, sign = yandex_sign(full_id)
            lyrics_params = urllib.parse.urlencode({"format": "LRC", "timeStamp": timestamp, "sign": sign})
            lyrics = yandex_result(f"https://api.music.yandex.net/tracks/{full_id}/lyrics?{lyrics_params}")
            download_url = (lyrics or {}).get("downloadUrl")
            if not download_url:
                write_lyrics_cache(full_id, key, None)
                continue

            request = urllib.request.Request(download_url, headers={"User-Agent": "Yandex-Music-API"})
            with urllib.request.urlopen(request, timeout=YANDEX_TIMEOUT) as response:
                parsed = parse_lrc(response.read().decode("utf-8"))
            if parsed:
                write_lyrics_cache(full_id, key, parsed)
                return parsed
            write_lyrics_cache(full_id, key, None)
    except Exception:
        return None

    return None


def lyric_at(lines: list[tuple[int, str]], position_ms: int) -> str | None:
    index = bisect.bisect_right(lines, (position_ms, chr(0x10FFFF))) - 1
    if index < 0:
        return None
    return lines[index][1]


def lyrics_tooltip(lines: list[tuple[int, str]], position_ms: int, count: int = 6) -> str:
    index = bisect.bisect_right(lines, (position_ms, chr(0x10FFFF))) - 1
    index = max(index, 0)
    return "\n".join(line for _time_ms, line in lines[index : index + count])


def playback_position_ms(status: str, position_ms: int, sampled_at: float, now: float) -> int:
    if status != "Playing" or not sampled_at:
        return position_ms
    return position_ms + int((now - sampled_at) * 1000)


def write_state(key: tuple[str, str, str], lines: list[tuple[int, str]] | None) -> None:
    payload = {"track": list(key), "times": [line[0] for line in lines or []]}
    tmp_file = f"{STATE_FILE}.tmp"
    with open(tmp_file, "w", encoding="utf-8") as state:
        json.dump(payload, state)
    os.replace(tmp_file, STATE_FILE)


def read_state() -> tuple[tuple[str, str, str], list[int]]:
    try:
        with open(STATE_FILE, encoding="utf-8") as state:
            payload = json.load(state)
        track = payload.get("track") or ["", "", ""]
        times = [int(item) for item in payload.get("times") or []]
        return (str(track[0]), str(track[1]), str(track[2])), times
    except Exception:
        return ("", "", ""), []


def seek_line(direction: str) -> int:
    bus = dbus.SessionBus()
    player_name = find_mpris_player(bus)
    if not player_name:
        return 1

    try:
        obj = bus.get_object(player_name, "/org/mpris/MediaPlayer2")
        props = dbus.Interface(obj, "org.freedesktop.DBus.Properties")
        player = dbus.Interface(obj, "org.mpris.MediaPlayer2.Player")
        metadata = props.Get("org.mpris.MediaPlayer2.Player", "Metadata")
        current_key = (
            metadata_value(metadata.get("xesam:title")),
            metadata_value(metadata.get("xesam:artist")),
            metadata_value(metadata.get("xesam:album")),
        )
        state_key, times = read_state()
        if current_key != state_key or not times:
            return 1

        position_ms = int(props.Get("org.mpris.MediaPlayer2.Player", "Position") or 0) // 1000
        if direction == "prev":
            index = bisect.bisect_left(times, position_ms - 500) - 1
        else:
            index = bisect.bisect_right(times, position_ms + LYRIC_LEAD_MS)
        if not 0 <= index < len(times):
            return 1

        player.SetPosition(metadata.get("mpris:trackid"), dbus.Int64(times[index] * 1000))
        return 0
    except dbus.DBusException:
        return 1


def stop_process(proc: subprocess.Popen | None) -> None:
    if proc is None or proc.poll() is not None:
        return
    proc.terminate()
    try:
        proc.wait(timeout=1)
    except subprocess.TimeoutExpired:
        proc.kill()


def start_sptlrx(out: queue.Queue[str]) -> subprocess.Popen:
    proc = subprocess.Popen(
        ["sptlrx", "-p", "mpris", "pipe"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )

    def reader() -> None:
        if proc.stdout is None:
            return
        for line in proc.stdout:
            out.put(ANSI_RE.sub("", line).strip())

    threading.Thread(target=reader, daemon=True).start()
    return proc


def drain_latest(out: queue.Queue[str]) -> str | None:
    latest = None
    while True:
        try:
            latest = out.get_nowait()
        except queue.Empty:
            return latest


def main() -> int:
    bus = dbus.SessionBus()
    proc = None
    out: queue.Queue[str] = queue.Queue()
    last_emit = None
    last_track = ("", "", "")
    last_sptlrx_line = 0.0
    sptlrx_started_at = 0.0
    next_mpris_check = 0.0
    next_animation = 0.0
    animation_index = 0
    have_raw_output = False
    real_lyrics_seen = False
    showing_silence = False
    lyrics_available = None
    yandex_cache: dict[tuple[str, str, str], list[tuple[int, str]] | None] = {}
    direct_lyrics: list[tuple[int, str]] | None = None
    no_lyrics_retry_at = 0.0
    status = ""
    current_track = ("", "", "")
    current_position_ms = 0
    current_position_sampled_at = 0.0
    player_name = ""

    while True:
        now = time.monotonic()

        if now >= next_mpris_check:
            previous_status = status
            previous_track = current_track
            predicted_position_ms = playback_position_ms(
                previous_status,
                current_position_ms,
                current_position_sampled_at,
                now,
            )
            status, current_track, mpris_position_ms, player_name = read_mpris(bus, player_name)
            if (
                status == "Playing"
                and previous_status == "Playing"
                and current_track == previous_track
                and abs(mpris_position_ms - predicted_position_ms) <= POSITION_JITTER_MS
            ):
                current_position_ms = predicted_position_ms
            else:
                current_position_ms = mpris_position_ms
            current_position_sampled_at = now
            next_mpris_check = now + MPRIS_CHECK_INTERVAL

            if status == "Paused" and has_track(current_track):
                stop_process(proc)
                proc = None
                out = queue.Queue()
                if last_emit != LYRIC_ICON:
                    emit(LYRIC_ICON, "paused")
                    last_emit = LYRIC_ICON

            elif status != "Playing" or not has_track(current_track):
                stop_process(proc)
                proc = None
                out = queue.Queue()
                last_track = ("", "", "")
                direct_lyrics = None
                write_state(("", "", ""), None)
                if last_emit != "":
                    emit("")
                    last_emit = ""

            elif current_track != last_track:
                stop_process(proc)
                proc = None
                out = queue.Queue()
                last_track = current_track
                last_sptlrx_line = 0.0
                sptlrx_started_at = 0.0
                have_raw_output = False
                real_lyrics_seen = False
                showing_silence = True
                next_animation = 0.0
                if current_track not in yandex_cache:
                    yandex_cache[current_track] = fetch_yandex_lrc(current_track)
                direct_lyrics = yandex_cache[current_track]
                write_state(current_track, direct_lyrics)
                lyrics_available = True if direct_lyrics else has_synced_lyrics(current_track)
                no_lyrics_retry_at = 0.0

        if status == "Playing" and has_track(current_track):
            if direct_lyrics:
                stop_process(proc)
                proc = None
                out = queue.Queue()
                render_position_ms = playback_position_ms(status, current_position_ms, current_position_sampled_at, now)
                line = lyric_at(direct_lyrics, render_position_ms + LYRIC_LEAD_MS)
                if line:
                    text = f"{LYRIC_ICON} {line}"
                    if text != last_emit:
                        emit(text, "active", lyrics_tooltip(direct_lyrics, render_position_ms + LYRIC_LEAD_MS))
                        last_emit = text
                elif now >= next_animation:
                    frame = SILENCE_FRAMES[animation_index % len(SILENCE_FRAMES)]
                    animation_index += 1
                    next_animation = now + ANIMATION_INTERVAL
                    text = f"{LYRIC_ICON} {frame}"
                    if text != last_emit:
                        emit(text, "active")
                        last_emit = text
                time.sleep(QUEUE_CHECK_INTERVAL)
                continue

            if lyrics_available is None and no_lyrics_retry_at and now >= no_lyrics_retry_at:
                no_lyrics_retry_at = 0.0
                showing_silence = True
                next_animation = 0.0

            if lyrics_available is False:
                stop_process(proc)
                proc = None
                out = queue.Queue()
                if last_emit != NO_LYRICS_TEXT:
                    emit(NO_LYRICS_TEXT, "active")
                    last_emit = NO_LYRICS_TEXT
                time.sleep(QUEUE_CHECK_INTERVAL)
                continue

            if lyrics_available is None and no_lyrics_retry_at:
                time.sleep(QUEUE_CHECK_INTERVAL)
                continue

            if proc is None or proc.poll() is not None:
                proc = start_sptlrx(out)
                last_sptlrx_line = now
                sptlrx_started_at = now
                have_raw_output = False
                real_lyrics_seen = False
                showing_silence = True
                next_animation = 0.0

            latest = drain_latest(out)
            if latest is not None:
                last_sptlrx_line = now
                have_raw_output = True
                if latest == "..." or latest == "":
                    showing_silence = True
                    next_animation = 0.0
                elif latest == "(no lyrics)":
                    lyrics_available = False
                    showing_silence = False
                    if last_emit != NO_LYRICS_TEXT:
                        emit(NO_LYRICS_TEXT, "active")
                        last_emit = NO_LYRICS_TEXT
                else:
                    real_lyrics_seen = True
                    showing_silence = False
                    text = f"{LYRIC_ICON} {latest}"
                    if text != last_emit:
                        emit(text, "active")
                        last_emit = text

            if showing_silence and now >= next_animation:
                frame = SILENCE_FRAMES[animation_index % len(SILENCE_FRAMES)]
                animation_index += 1
                next_animation = now + ANIMATION_INTERVAL
                text = f"{LYRIC_ICON} {frame}"
                if text != last_emit:
                    emit(text, "active")
                    last_emit = text

            if have_raw_output and now - last_sptlrx_line > SPTLRX_STALE_AFTER:
                stop_process(proc)
                proc = None
                out = queue.Queue()
                last_sptlrx_line = now
                sptlrx_started_at = 0.0
                have_raw_output = False
                real_lyrics_seen = False
                showing_silence = True
                next_animation = 0.0

            if lyrics_available is None and not real_lyrics_seen and now - sptlrx_started_at > NO_LYRICS_AFTER:
                stop_process(proc)
                proc = None
                out = queue.Queue()
                no_lyrics_retry_at = now + NO_LYRICS_RETRY_AFTER
                showing_silence = False
                if last_emit != NO_LYRICS_TEXT:
                    emit(NO_LYRICS_TEXT, "active")
                    last_emit = NO_LYRICS_TEXT

        time.sleep(QUEUE_CHECK_INTERVAL)


if __name__ == "__main__":
    try:
        if len(sys.argv) == 3 and sys.argv[1] == "seek" and sys.argv[2] in {"next", "prev"}:
            raise SystemExit(seek_line(sys.argv[2]))
        raise SystemExit(main())
    except KeyboardInterrupt:
        sys.exit(130)
